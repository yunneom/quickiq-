# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Business info (전자상거래법 제13조 사업자정보) — required for the KakaoPay /
# card-issuer merchant review. When all six mandatory fields are set, the
# seller-identity footer appears on every page and the terms page shows the
# full block. Public info (legally must be displayed), but kept in env so
# it's not hard-committed. MAILORDER_NO is optional (use "면제" when exempt).
NEXT_PUBLIC_BIZ_NAME=
NEXT_PUBLIC_BIZ_CEO=
NEXT_PUBLIC_BIZ_REG_NO=
NEXT_PUBLIC_BIZ_ADDRESS=
NEXT_PUBLIC_BIZ_TEL=
NEXT_PUBLIC_BIZ_EMAIL=
NEXT_PUBLIC_BIZ_MAILORDER_NO=

# Kakao Pay (KR) — highest-priority processor when KAKAOPAY_SECRET_KEY is
# set. Uses the current KakaoPay Developers API (open-api.kakaopay.com):
#   /online/v1/payment/ready    → tid + redirect URL
#   /online/v1/payment/approve  → authoritative confirm
# Credentials from KakaoPay Developers → 애플리케이션 → 발급정보:
#   KAKAOPAY_SECRET_KEY — Secret Key, sent as `Authorization: SECRET_KEY {key}`.
#                         Use the dev Secret Key for testing. Server-only.
#   KAKAOPAY_CID        — Merchant CID (separate from Client ID). Defaults to
#                         TC0ONETIME (official test CID); swap for your live
#                         CID once onboarding is approved.
#   KAKAOPAY_CLIENT_ID  — Client ID (20-char). Identifies the merchant; not
#                         sent per request, kept for ops/contract parity.
KAKAOPAY_SECRET_KEY=
KAKAOPAY_CID=TC0ONETIME
KAKAOPAY_CLIENT_ID=

# Toss Payments (KR) — used when Kakao Pay is not configured. When both
# keys are set, /api/checkout returns Toss mode and the client opens the
# Toss payment UI. Get these from the Toss merchant dashboard (개발자센터
# → API 키). The client key is public (NEXT_PUBLIC); the secret key is
# server-only — never expose it.
NEXT_PUBLIC_TOSS_CLIENT_KEY=
TOSS_SECRET_KEY=

# Lemon Squeezy (fallback; used only when neither Kakao nor Toss is set)
LEMON_SQUEEZY_API_KEY=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_PRODUCT_VARIANT_ID=
LEMON_SQUEEZY_WEBHOOK_SECRET=

# Resend
RESEND_API_KEY=
RESEND_FROM_EMAIL=report@yourdomain.com

# Meta Pixel + Conversion API
NEXT_PUBLIC_META_PIXEL_ID=
META_CAPI_ACCESS_TOKEN=

# Kakao Share (optional, Korean market)
NEXT_PUBLIC_KAKAO_APP_KEY=
# Kakao channel public id (slug after pf.kakao.com/). Enables the
# "카카오톡 채널 추가" button on the thank-you page.
NEXT_PUBLIC_KAKAO_CHANNEL_ID=

# Google AdSense — leave BOTH unset until AdSense approval. Setting the
# client id turns on the page-level loader script + /ads.txt; setting the
# slot id additionally renders the responsive display unit on free pages
# (personality results, type pages, /tests hub — never the paid funnel).
# Client id format: ca-pub-XXXXXXXXXXXXXXXX. Slot id: digits only, from
# the AdSense dashboard after creating a display ad unit.
NEXT_PUBLIC_ADSENSE_CLIENT=
NEXT_PUBLIC_ADSENSE_SLOT=

# Question pool — leave unset for deterministic 30 questions in order
# (PRD default). Set to "shuffle" to draw 30 random questions per session
# from the combined base + extra pool (better repeat-attempt variation).
NEXT_PUBLIC_QUESTION_POOL=

# Landing-page A/B variant — leave unset (= variant A) or set to "b" to
# swap headline/sub/cta for the variant-B copy. Use this for ad-creative
# experiments without a code change.
NEXT_PUBLIC_LANDING_VARIANT=

# Auto-advance behavior — leave unset (= auto-advance after 350ms) or
# set to "off" to require an explicit "Next" button tap after each
# answer. Useful for users who want to review their selection.
NEXT_PUBLIC_AUTO_ADVANCE=

# Admin dashboard token — required to access /api/admin/stats.
# Generate something long (e.g. `openssl rand -hex 32`) and keep it secret.
ADMIN_TOKEN=

# Sentry (optional) — DSN is enough for runtime error capture.
# SENTRY_ORG / SENTRY_PROJECT / SENTRY_AUTH_TOKEN are only needed to upload
# sourcemaps during production builds (CI).
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_DSN=
SENTRY_ORG=
SENTRY_PROJECT=
SENTRY_AUTH_TOKEN=

# Vercel Analytics & Speed Insights — no env vars required.
# The @vercel/analytics package auto-detects when running on Vercel and
# stays silent everywhere else.

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Price in KRW won (4900 = 4,900원). A/B test prices by setting
# different values per Vercel environment (Production / Preview), e.g.
# 3900 for an aggressive discount test or 7900 for a premium test.
# The KO label is auto-formatted with thousands separator; the EN label
# converts at the configurable peg below (default 1 USD ≈ 1,320 KRW).
NEXT_PUBLIC_PRICE_KRW=4900
# Informational USD/KRW peg used to render the EN $-label. Lemon Squeezy
# MoR handles the *actual* FX at charge time, so this only affects what
# the EN audience sees on the landing/checkout. Update when KRW drifts.
NEXT_PUBLIC_USD_KRW_PEG=1320
